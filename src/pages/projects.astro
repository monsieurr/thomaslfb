---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const pageTitle = "Case Studies | Thomas L.";
const allProjects = await getCollection('projects', ({ data }) => !data.isDraft);
const projects = allProjects.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

// Toggle this if you want GitHub/Demo links directly on the cards.
const showCardLinks = true;
---
<BaseLayout title={pageTitle}>
  <section class="projects-section">
    <span class="eyebrow">Selected Work</span>
    <h1>Case Studies</h1>
    <p>Personal case studies at the intersection of data, ESG, AI, and regulations, presented with a PRD-style breakdown plus links to code and live demos.</p>
    <p class="projects-note">If you also want to see what I have done in a professional setting, please see my <a href="/cv">CV</a> or contact me directly.</p>

    {projects.length === 0 ? (
      <p class="empty-state">No projects published yet.</p>
    ) : (
      <div class="grid-bento projects-grid">
        {projects.map((project) => (
          showCardLinks ? (
            <article class="card project-card" data-project={project.slug}>
              <a href={`/projects/${project.slug}`} class="project-main-link" aria-label={`Open ${project.data.title}`}>
                <h3>
                  {project.data.emoji && <span class="project-emoji">{project.data.emoji}</span>}
                  {project.data.title}
                </h3>
                <p class="description">{project.data.description}</p>
              </a>

              {(project.data.tags || project.data.techStack) && (
                <div class="card-tags">
                  {((project.data.tags ?? project.data.techStack) ?? []).slice(0, 6).map((tag) => (
                    <span>#{tag}</span>
                  ))}
                </div>
              )}

              {(project.data.demoUrl || project.data.repoUrl) && (
                <div class="card-actions">
                  {project.data.demoUrl && (
                    <a href={project.data.demoUrl} target="_blank" rel="noopener noreferrer" class="card-action">
                      Demo ↗
                    </a>
                  )}
                  {project.data.repoUrl && (
                    <a href={project.data.repoUrl} target="_blank" rel="noopener noreferrer" class="card-action">
                      GitHub ↗
                    </a>
                  )}
                </div>
              )}
            </article>
          ) : (
            <a href={`/projects/${project.slug}`} class="card project-card" data-project={project.slug} aria-label={`Open ${project.data.title}`}>
              <div>
                <h3>
                  {project.data.emoji && <span class="project-emoji">{project.data.emoji}</span>}
                  {project.data.title}
                </h3>
                <p class="description">{project.data.description}</p>
              </div>

              {(project.data.tags || project.data.techStack) && (
                <div class="card-tags">
                  {((project.data.tags ?? project.data.techStack) ?? []).slice(0, 6).map((tag) => (
                    <span>#{tag}</span>
                  ))}
                </div>
              )}
            </a>
          )
        ))}
      </div>
    )}
  </section>
</BaseLayout>

<style>
  .projects-section {
    padding-bottom: 4rem;
  }

  .projects-grid {
    margin-top: 2.5rem;
  }

  .project-card {
    background-image: none;
    color: inherit;
    text-decoration: none;
  }

  .project-card h3 {
    margin-bottom: 0.75rem;
  }

  .project-emoji {
    margin-right: 0.5rem;
  }

  .project-card .description {
    color: var(--text-muted);
    margin-bottom: 0;
    font-size: 1rem;
  }

  .project-main-link {
    display: block;
    background-image: none;
    color: inherit;
  }

  .project-main-link:hover {
    color: inherit;
  }

  .card-actions {
    margin-top: 1.25rem;
    display: flex;
    gap: 1rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
  }

  .card-action {
    background-image: none;
    color: var(--text-main);
  }

  .card-action:hover {
    color: var(--accent);
  }

  .card-tags {
    margin-top: 1rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .card-tags span {
    background: #f4f4f5;
    padding: 2px 6px;
    border-radius: 4px;
  }

  .project-card[data-project="hibou"] {
    background: linear-gradient(180deg, #f6f1ea 0%, #ffffff 65%);
  }

  .project-card[data-project="girafon"] {
    background: linear-gradient(180deg, #fff6e9 0%, #ffffff 65%);
  }

  .project-card[data-project="koala"] {
    background: linear-gradient(180deg, #f2f3f5 0%, #ffffff 65%);
  }

  .empty-state {
    font-style: italic;
  }

  .projects-note {
    margin-top: 0.75rem;
  }

  @media (min-width: 900px) {
    .projects-grid {
      grid-template-columns: repeat(3, minmax(260px, 1fr));
      gap: 1.5rem;
    }
  }
</style>
