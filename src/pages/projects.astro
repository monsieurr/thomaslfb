---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const pageTitle = "Projects | Thomas L.";
const allProjects = await getCollection('projects', ({ data }) => !data.isDraft);
const projects = allProjects.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

// Toggle this if you want GitHub/Demo links directly on the cards.
const showCardLinks = false;
---
<BaseLayout title={pageTitle}>
  <section class="projects-section">
    <span class="eyebrow">Portfolio</span>
    <h1>Projects</h1>
    <p>Case studies and builds with a PRD-style breakdown, plus links to code and live demos.</p>

    {projects.length === 0 ? (
      <p class="empty-state">No projects published yet.</p>
    ) : (
      <div class="grid-bento projects-grid">
        {projects.map((project) => (
          showCardLinks ? (
            <article class="card project-card">
              <a href={`/projects/${project.slug}`} class="project-main-link" aria-label={`Open ${project.data.title}`}>
                <h3>{project.data.title}</h3>
                <p class="description">{project.data.description}</p>
              </a>

              {project.data.techStack && (
                <div class="card-meta">
                  {project.data.techStack.slice(0, 3).map((stack) => <span>{stack}</span>)}
                </div>
              )}

              {(project.data.demoUrl || project.data.repoUrl) && (
                <div class="card-actions">
                  {project.data.demoUrl && (
                    <a href={project.data.demoUrl} target="_blank" rel="noopener noreferrer" class="card-action">
                      Demo ↗
                    </a>
                  )}
                  {project.data.repoUrl && (
                    <a href={project.data.repoUrl} target="_blank" rel="noopener noreferrer" class="card-action">
                      GitHub ↗
                    </a>
                  )}
                </div>
              )}
            </article>
          ) : (
            <a href={`/projects/${project.slug}`} class="card project-card" aria-label={`Open ${project.data.title}`}>
              <div>
                <h3>{project.data.title}</h3>
                <p class="description">{project.data.description}</p>
              </div>

              {project.data.techStack && (
                <div class="card-meta">
                  {project.data.techStack.slice(0, 3).map((stack) => <span>{stack}</span>)}
                </div>
              )}
            </a>
          )
        ))}
      </div>
    )}
  </section>
</BaseLayout>

<style>
  .projects-section {
    padding-bottom: 4rem;
  }

  .projects-grid {
    margin-top: 2.5rem;
  }

  .project-card {
    background-image: none;
    color: inherit;
    text-decoration: none;
  }

  .project-card h3 {
    margin-bottom: 0.75rem;
  }

  .project-card .description {
    color: var(--text-muted);
    margin-bottom: 0;
    font-size: 1rem;
  }

  .project-main-link {
    display: block;
    background-image: none;
    color: inherit;
  }

  .project-main-link:hover {
    color: inherit;
  }

  .card-actions {
    margin-top: 1.25rem;
    display: flex;
    gap: 1rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
  }

  .card-action {
    background-image: none;
    color: var(--text-main);
  }

  .card-action:hover {
    color: var(--accent);
  }

  .empty-state {
    font-style: italic;
  }
</style>
